<UserControl
    x:Class="ProgrammersToolKit.Views.DiffEditorPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProgrammersToolKit.Views">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBox x:Name="LeftTextBox" Grid.Row="0" AcceptsReturn="True" FontFamily="Consolas" FontSize="14" Watermark="Paste or type original text here..."/>
        <TextBox x:Name="RightTextBox" Grid.Row="1" AcceptsReturn="True" FontFamily="Consolas" FontSize="14" Watermark="Paste or type modified text here..."/>
        <Button Grid.Row="2" Content="Compare" Click="CompareButton_Click" Margin="0,10,0,0"/>
    </Grid>
</UserControl>
