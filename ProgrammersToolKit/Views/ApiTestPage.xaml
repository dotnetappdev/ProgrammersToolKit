<UserControl
    x:Class="ProgrammersToolKit.Views.ApiTestPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProgrammersToolKit.Views">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="10">
            <TextBlock Text="API Test List" FontWeight="Bold" FontSize="18" Margin="0,0,0,10"/>
            <ListBox x:Name="ApiTestListBox" Height="400"/>
            <Button Content="Run Selected Test" Margin="0,10,0,0"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="10">
            <TextBlock Text="Test Details" FontWeight="Bold" FontSize="18" Margin="0,0,0,10"/>
            <TextBox x:Name="TestNameBox" Watermark="Name"/>
            <TextBox x:Name="TestUrlBox" Watermark="URL"/>
            <ComboBox x:Name="TestMethodBox" Watermark="Method">
                <ComboBoxItem Content="GET"/>
                <ComboBoxItem Content="POST"/>
                <ComboBoxItem Content="PUT"/>
                <ComboBoxItem Content="DELETE"/>
            </ComboBox>
            <Expander Watermark="Headers" IsExpanded="False" Margin="0,5,0,0">
                <TextBox x:Name="TestHeadersBox" AcceptsReturn="True" Height="60" Watermark="Key: Value&#x0A;Key2: Value2"/>
            </Expander>
            <TabControl Margin="0,5,0,0">
                <TabItem Watermark="Raw">
                    <TextBox x:Name="TestBodyBox" AcceptsReturn="True" Height="80" Watermark="Paste raw body here (JSON, XML, etc.)"/>
                </TabItem>
                <TabItem Watermark="JSON">
                    <TextBox x:Name="TestBodyJsonBox" AcceptsReturn="True" Height="80" Watermark="Paste JSON body here..."/>
                </TabItem>
                <TabItem Watermark="XML">
                    <TextBox x:Name="TestBodyXmlBox" AcceptsReturn="True" Height="80" Watermark="Paste XML body here..."/>
                </TabItem>
            </TabControl>
            <ComboBox x:Name="TestBodyTypeBox" Watermark="Body Type">
                <ComboBoxItem Content="Raw"/>
                <ComboBoxItem Content="JSON"/>
                <ComboBoxItem Content="XML"/>
            </ComboBox>
            <TextBox x:Name="TestAssertionsBox" Watermark="Assertions (NUnit style)"/>
            <Button Content="Save Test" Margin="0,10,0,0"/>
            <Button Content="Delete Test" Margin="0,5,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
