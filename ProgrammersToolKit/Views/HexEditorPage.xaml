<Page
    x:Class="ProgrammersToolKit.Views.HexEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProgrammersToolKit.Views">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Hex Editor" FontWeight="Bold" FontSize="18" Margin="0,0,0,10"/>
            <TextBox x:Name="HexInputBox" Header="Hex Input" AcceptsReturn="True" Height="100"/>
            <Button Content="To Text" Margin="0,10,0,0"/>
            <Button Content="To Hex" Margin="0,5,0,0"/>
            <TextBox x:Name="TextOutputBox" Header="Text Output" AcceptsReturn="True" Height="100"/>
        </StackPanel>
    </Grid>
</Page>
