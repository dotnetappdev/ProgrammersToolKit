<UserControl
    x:Class="ProgrammersToolKit.Views.JsonVisualizerPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProgrammersToolKit.Views">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="JsonInputBox" AcceptsReturn="True" FontFamily="Consolas" FontSize="14" Watermark="Paste or type JSON here..."/>
        <TabControl Grid.Column="1">
            <TabControlItem Watermark="Blueprint">
                <ScrollViewer>
                    <Canvas x:Name="BlueprintCanvas" Background="#222" Height="600"/>
                </ScrollViewer>
            </TabItem>
            <TabControlItem Watermark="Tree View">
                <TreeView x:Name="JsonTreeView"/>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
