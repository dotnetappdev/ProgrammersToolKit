<Page
    x:Class="ProgrammersToolKit.Views.EncodingDecodingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProgrammersToolKit.Views">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Encoding/Decoding Tool" FontWeight="Bold" FontSize="18" Margin="0,0,0,10"/>
            <TextBox x:Name="InputBox" Header="Input" AcceptsReturn="True" Height="80"/>
            <ComboBox x:Name="EncodingBox" Header="Encoding">
                <ComboBoxItem Content="Base64"/>
                <ComboBoxItem Content="URL"/>
                <ComboBoxItem Content="Hex"/>
            </ComboBox>
            <Button Content="Encode" Margin="0,10,0,0"/>
            <Button Content="Decode" Margin="0,5,0,0"/>
            <TextBox x:Name="OutputBox" Header="Output" AcceptsReturn="True" Height="80"/>
        </StackPanel>
    </Grid>
</Page>
