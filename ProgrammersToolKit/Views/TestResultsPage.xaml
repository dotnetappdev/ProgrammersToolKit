<UserControl
    x:Class="ProgrammersToolKit.Views.TestResultsPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProgrammersToolKit.Views">
    <Grid>
        <StackPanel>
            <TextBlock Text="Test Results" FontWeight="Bold" FontSize="18" Margin="0,0,0,10"/>
            <ListView x:Name="TestResultsListView">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <TextBlock Text="{Binding Name}" Width="160"/>
                            <TextBlock Text="{Binding Success}" Width="80"/>
                            <TextBlock Text="{Binding TestDate}" Width="120"/>
                            <TextBlock Text="{Binding ErrorMessage}" Width="200"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</UserControl>
