<UserControl
    x:Class="ProgrammersToolKit.Views.EncryptionToolPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProgrammersToolKit.Views">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Encryption/Decryption Tool" FontWeight="Bold" FontSize="18" Margin="0,0,0,10"/>
            <TextBox x:Name="InputBox" Watermark="Input" AcceptsReturn="True" Height="80"/>
            <ComboBox x:Name="AlgorithmBox" Watermark="Algorithm">
                <ComboBoxItem Content="Base64"/>
                <ComboBoxItem Content="AES"/>
                <ComboBoxItem Content="DES"/>
            </ComboBox>
            <TextBox x:Name="KeyBox" Watermark="Key (if needed)"/>
            <Button Content="Encrypt" Margin="0,10,0,0"/>
            <Button Content="Decrypt" Margin="0,5,0,0"/>
            <TextBox x:Name="OutputBox" Watermark="Output" AcceptsReturn="True" Height="80"/>
        </StackPanel>
    </Grid>
</UserControl>
