<UserControl
    x:Class="ProgrammersToolKit.Views.ApiTestResultDetailPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProgrammersToolKit.Views">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Test Result Details" FontWeight="Bold" FontSize="18" Margin="0,0,0,10"/>
            <TextBlock Text="Status Code:" FontWeight="SemiBold"/>
            <TextBlock x:Name="StatusCodeText" FontSize="16"/>
            <TextBlock Text="Headers:" FontWeight="SemiBold" Margin="0,10,0,0"/>
            <TextBox x:Name="HeadersBox" IsReadOnly="True" AcceptsReturn="True" Height="80"/>
            <TextBlock Text="Response Body:" FontWeight="SemiBold" Margin="0,10,0,0"/>
            <TabControl>
                <TabControlItem Watermark="Pretty">
                    <TextBox x:Name="PrettyBodyBox" IsReadOnly="True" AcceptsReturn="True" Height="200"/>
                </TabItem>
                <TabControlItem Watermark="Raw">
                    <TextBox x:Name="RawBodyBox" IsReadOnly="True" AcceptsReturn="True" Height="200"/>
                </TabItem>
            </TabControl>
            <TextBlock Text="Error Message:" FontWeight="SemiBold" Margin="0,10,0,0"/>
            <TextBox x:Name="ErrorBox" IsReadOnly="True" AcceptsReturn="True" Height="60"/>
        </StackPanel>
    </Grid>
</UserControl>
