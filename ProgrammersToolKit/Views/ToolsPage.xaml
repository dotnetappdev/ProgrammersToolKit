<UserControl
    x:Class="ProgrammersToolKit.Views.ToolsPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProgrammersToolKit.Views">
    <Grid>
        <StackPanel>
            <TextBlock Text="Ethical Hacking Tools" FontWeight="Bold" FontSize="18" Margin="0,0,0,10"/>
            <Button Content="Header Inspector" Margin="0,5,0,0"/>
            <Button Content="Encryption/Decryption" Margin="0,5,0,0"/>
            <Button Content="Hex Editor" Margin="0,5,0,0"/>
            <Button Content="Encoding/Decoding" Margin="0,5,0,0"/>
            <Button Content="Cookie Inspector" Margin="0,5,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
