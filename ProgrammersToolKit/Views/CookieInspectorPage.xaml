<UserControl
    x:Class="ProgrammersToolKit.Views.CookieInspectorPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProgrammersToolKit.Views">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Cookie Inspector" FontWeight="Bold" FontSize="18" Margin="0,0,0,10"/>
            <TextBox x:Name="CookieInputBox" Watermark="Paste Cookie Here" AcceptsReturn="True" Height="80"/>
            <Button Content="Parse Cookie" Margin="0,10,0,0"/>
            <ListView x:Name="ParsedCookieListView" Height="200"/>
        </StackPanel>
    </Grid>
</UserControl>
