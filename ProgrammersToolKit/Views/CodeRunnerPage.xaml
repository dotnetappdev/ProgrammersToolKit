<Page
    x:Class="ProgrammersToolKit.Views.CodeRunnerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProgrammersToolKit.Views">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Code Runner" FontWeight="Bold" FontSize="18" Margin="0,0,0,10"/>
            <ComboBox x:Name="LanguageBox" Header="Language">
                <ComboBoxItem Content="C#"/>
                <ComboBoxItem Content="Python"/>
                <ComboBoxItem Content="JavaScript"/>
            </ComboBox>
            <local:SimpleCodeEditor x:Name="CodeInputBox" Height="120"/>
            <Button Content="Run Code" Margin="0,10,0,0" Click="RunCode_Click"/>
            <TextBlock Text="Test Cases:" FontWeight="SemiBold" Margin="0,10,0,0"/>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="NewTestCaseTextBox" Width="200" PlaceholderText="Enter test case input..."/>
                <Button Content="Add" Margin="5,0,0,0" Click="AddTestCaseButton_Click"/>
                <Button Content="Run All" Margin="5,0,0,0" Click="RunAllTestCasesButton_Click"/>
            </StackPanel>
            <ListView x:Name="TestCaseResultsListView" Height="100" Margin="0,5,0,0"/>
            <TextBlock Text="Output:" FontWeight="SemiBold" Margin="0,10,0,0"/>
            <TextBox x:Name="CodeOutputBox" IsReadOnly="True" AcceptsReturn="True" Height="80"/>
        </StackPanel>
    </Grid>
</Page>
