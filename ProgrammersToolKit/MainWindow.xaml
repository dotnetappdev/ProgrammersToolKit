<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ProgrammersToolKit.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProgrammersToolKit"
    Title="ProgrammersToolKit"
    Width="1200"
    Height="800">

    <Grid>
        <DockPanel>
            <!-- Side Navigation Panel -->
            <StackPanel DockPanel.Dock="Left" Width="250" Background="{DynamicResource SystemChromeLowColor}">
                <TextBox x:Name="SearchBox" Watermark="Search..." Margin="10"/>
                <Separator />
                <ListBox x:Name="MainNavList" SelectionChanged="MainNavList_SelectionChanged">
                    <ListBoxItem Content="API Tests" Tag="ApiTestPage"/>
                    <ListBoxItem Content="Test Results" Tag="TestResultsPage"/>
                    <ListBoxItem Content="Tools" Tag="ToolsPage"/>
                    <Separator />
                    <ListBoxItem Content="Header Inspector" Tag="HeaderInspectorPage"/>
                    <ListBoxItem Content="Encryption/Decryption" Tag="EncryptionToolPage"/>
                    <ListBoxItem Content="Hex Editor" Tag="HexEditorPage"/>
                    <ListBoxItem Content="Encoding/Decoding" Tag="EncodingDecodingPage"/>
                    <ListBoxItem Content="Cookie Inspector" Tag="CookieInspectorPage"/>
                    <ListBoxItem Content="Code Runner" Tag="CodeRunnerPage"/>
                    <ListBoxItem Content="Diff Editor" Tag="DiffEditorPage"/>
                    <ListBoxItem Content="JSON Visualizer" Tag="JsonVisualizerPage"/>
                    <ListBoxItem Content="SQL Query Window" Tag="SqlQueryWindow"/>
                </ListBox>
            </StackPanel>
            <!-- Main Content Area -->
            <ContentControl x:Name="ContentFrame" />
        </DockPanel>
    </Grid>
</Window>
