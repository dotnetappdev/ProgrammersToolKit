@page "/code-runner"
@using BlazorMonaco
@using BlazorMonaco.Editor
@using ProgrammersToolKit.Services.Interfaces
@inject ICodeRunnerService CodeRunnerService

<PageTitle>Code Runner - ProgrammersToolKit</PageTitle>

<div class="card">
    <h1 class="page-title">Code Runner</h1>
    
    <div class="form-group">
        <label class="form-label">Language:</label>
        <select class="form-control" @bind:get="selectedLanguage" @bind:set="SetSelectedLanguage" style="width: 200px;">
            <option value="csharp">C#</option>
            <option value="python">Python</option>
            <option value="javascript">JavaScript</option>
        </select>
    </div>

    <div class="form-group">
        <label class="form-label">Code Editor:</label>
        <div style="height: 400px; border: 1px solid #ccc;">
            <StandaloneCodeEditor @ref="codeEditor" Id="code-editor" ConstructionOptions="EditorConstructionOptions" />
        </div>
    </div>

    <div class="form-group">
        <button class="btn btn-primary" @onclick="RunCode" disabled="@isRunning">
            @if (isRunning)
            {
                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                <text>&nbsp;Running...</text>
            }
            else
            {
                <text>Run Code</text>
            }
        </button>
    </div>

    <div class="form-group">
        <label class="form-label">Input (for stdin):</label>
        <textarea class="form-control" @bind="codeInput" rows="3" placeholder="Enter input for your program here (optional)..."></textarea>
    </div>

    <div class="form-group">
        <label class="form-label">Test Cases:</label>
        <div style="display: flex; gap: 10px; margin-bottom: 10px;">
            <input type="text" class="form-control" @bind="newTestCase" placeholder="Enter test case input..." style="width: 300px;" />
            <button class="btn btn-secondary" @onclick="AddTestCase">Add</button>
            <button class="btn btn-primary" @onclick="RunAllTestCases" disabled="@isRunning">Run All</button>
        </div>
        
        @if (testCases.Any())
        {
            <div style="max-height: 150px; overflow-y: auto; border: 1px solid #ccc; padding: 10px;">
                @foreach (var testCase in testCases.Select((tc, index) => new { TestCase = tc, Index = index }))
                {
                    <div style="margin-bottom: 5px; padding: 5px; background: #f8f9fa; border-radius: 3px;">
                        <strong>Input:</strong> @testCase.TestCase.Input
                        <button class="btn btn-sm btn-outline-danger" style="float: right;" @onclick="() => RemoveTestCase(testCase.Index)">×</button>
                        @if (!string.IsNullOrEmpty(testCase.TestCase.Output))
                        {
                            <br /><strong>Output:</strong> 
                            <pre style="margin: 0; font-size: 12px; background: #e9ecef; padding: 2px;">@testCase.TestCase.Output</pre>
                        }
                    </div>
                }
            </div>
        }
    </div>

    <div class="form-group">
        <label class="form-label">Output:</label>
        <pre class="form-control" readonly style="height: 180px; font-family: 'Courier New', monospace; white-space: pre-wrap; overflow-y: auto;">@output</pre>
    </div>
</div>

@code {
    private StandaloneCodeEditor? codeEditor;
    private string selectedLanguage = "csharp";
    private string output = "";
    private string codeInput = "";
    private string newTestCase = "";
    private bool isRunning = false;
    private List<TestCase> testCases = new();

    public class TestCase
    {
        public string Input { get; set; } = "";
        public string Output { get; set; } = "";
    }

    private StandaloneEditorConstructionOptions EditorConstructionOptions(StandaloneCodeEditor editor)
    {
        return new StandaloneEditorConstructionOptions
        {
            AutomaticLayout = true,
            Language = GetMonacoLanguage(selectedLanguage),
            Value = GetDefaultCode(selectedLanguage),
            Theme = "vs",
            Minimap = new EditorMinimapOptions { Enabled = false },
            ScrollBeyondLastLine = false,
            ReadOnly = false,
            OverviewRulerBorder = false,
            OverviewRulerLanes = 0,
            LineHeight = 18,
            FontSize = 14
        };
    }

    private string GetMonacoLanguage(string language)
    {
        return language switch
        {
            "csharp" => "csharp",
            "python" => "python",
            "javascript" => "javascript",
            _ => "plaintext"
        };
    }

    private string GetDefaultCode(string language)
    {
        return language switch
        {
            "csharp" => @"using System;

class Program
{
    static void Main()
    {
        Console.WriteLine(""Hello, World!"");
        
        // Read input if provided
        string input = Console.ReadLine();
        if (!string.IsNullOrEmpty(input))
        {
            Console.WriteLine($""You entered: {input}"");
        }
    }
}",
            "python" => @"print(""Hello, World!"")

# Read input if provided
try:
    user_input = input()
    if user_input:
        print(f""You entered: {user_input}"")
except EOFError:
    pass",
            "javascript" => @"console.log(""Hello, World!"");

// Read input if provided (Node.js)
const readline = require('readline');
const rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout
});

rl.question('', (input) => {
    if (input) {
        console.log(`You entered: ${input}`);
    }
    rl.close();
});",
            _ => "// Enter your code here"
        };
    }

    private async Task SetSelectedLanguage(string language)
    {
        selectedLanguage = language;
        if (codeEditor != null)
        {
            await codeEditor.SetValue(GetDefaultCode(selectedLanguage));
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && codeEditor != null)
        {
            await codeEditor.SetValue(GetDefaultCode(selectedLanguage));
        }
    }

    private async Task RunCode()
    {
        if (codeEditor == null || isRunning) return;

        isRunning = true;
        StateHasChanged();

        try
        {
            var code = await codeEditor.GetValue();
            
            if (string.IsNullOrWhiteSpace(code))
            {
                output = "Error: No code to execute";
                return;
            }

            output = "Executing code...\n";
            StateHasChanged();

            var result = await CodeRunnerService.RunCodeWithInputAsync(code, selectedLanguage, codeInput);
            output = result;
        }
        catch (Exception ex)
        {
            output = $"Error: {ex.Message}";
        }
        finally
        {
            isRunning = false;
            StateHasChanged();
        }
    }

    private void AddTestCase()
    {
        if (!string.IsNullOrWhiteSpace(newTestCase))
        {
            testCases.Add(new TestCase { Input = newTestCase });
            newTestCase = "";
        }
    }

    private void RemoveTestCase(int index)
    {
        if (index >= 0 && index < testCases.Count)
        {
            testCases.RemoveAt(index);
        }
    }

    private async Task RunAllTestCases()
    {
        if (codeEditor == null || isRunning || !testCases.Any()) return;

        isRunning = true;
        StateHasChanged();

        try
        {
            var code = await codeEditor.GetValue();
            
            if (string.IsNullOrWhiteSpace(code))
            {
                output = "Error: No code to execute";
                return;
            }

            output = $"Running {testCases.Count} test cases...\n";
            StateHasChanged();

            foreach (var testCase in testCases)
            {
                testCase.Output = "Running...";
                StateHasChanged();
                
                var result = await CodeRunnerService.RunCodeWithInputAsync(code, selectedLanguage, testCase.Input);
                testCase.Output = result;
                StateHasChanged();
            }
            
            output = $"Completed running {testCases.Count} test cases. Check individual results above.";
        }
        catch (Exception ex)
        {
            output = $"Error running test cases: {ex.Message}";
        }
        finally
        {
            isRunning = false;
            StateHasChanged();
        }
    }
}