<UserControl
    x:Class="ProgrammersToolKit.Controls.SimpleCodeEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProgrammersToolKit.Controls">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="40"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- Line numbers -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Grid.Column="0" Grid.Row="0">
            <StackPanel x:Name="LineNumbersPanel"/>
        </ScrollViewer>
        <!-- Code editor -->
        <RichEditBox x:Name="EditorBox" Grid.Column="1" Grid.Row="0" AcceptsReturn="True" FontFamily="Consolas" FontSize="14" TextChanged="EditorBox_TextChanged"/>
        <!-- Terminal/Debug window -->
        <Grid Grid.Row="1" Grid.ColumnSpan="2" Background="#1e1e1e">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Grid.Row="0">
                <TextBlock x:Name="TerminalOutputBlock" FontFamily="Consolas" FontSize="13" Foreground="White" TextWrapping="Wrap"/>
            </ScrollViewer>
            <StackPanel Orientation="Horizontal" Grid.Row="1" Background="#222">
                <TextBox x:Name="TerminalInputBox" Width="Auto" MinWidth="60" Margin="2,2,0,2" FontFamily="Consolas" FontSize="13" KeyDown="TerminalInputBox_KeyDown"/>
                <Button Content="Send" Margin="4,2,0,2" Click="TerminalSendButton_Click"/>
                <Button Content="Copy All" Margin="4,2,2,2" Click="TerminalCopyAllButton_Click"/>
            </StackPanel>
        </Grid>
        <!-- Status bar -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#eee" Height="28" VerticalAlignment="Bottom">
            <TextBlock x:Name="StatusBarText" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12" Foreground="#444"/>
        </Border>
    </Grid>
</UserControl>
